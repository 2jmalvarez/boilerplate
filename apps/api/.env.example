NODE_ENV=development
PORT=3180
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/boilerplate
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ISSUER=boilerplate-api
JWT_AUDIENCE=boilerplate-clients
CORS_ORIGIN=http://localhost:5180
# Request logging: off, basic (method, URL, status, duration), or detailed (also params, query and body).
HTTP_LOG_LEVEL=detailed
# Set to false for log collectors that do not support ANSI colors.
HTTP_LOG_COLORS=true
# Optional; integration tests are skipped when absent.
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/boilerplate_test
